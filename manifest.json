{
  "manifest_version": 3,
  "name": "My Paste",
  "description": "按网站分组记录网页复制文本",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "打开 My Paste"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "My Paste",
    "default_popup": "popup.html"
  }
}